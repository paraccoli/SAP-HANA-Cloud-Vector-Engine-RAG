<div class="i18nContainer hidden">
<div class="trialsKeys" data-forms.registration.gatedassets-trials.headline.title="Thank you for your interest in SAP" data-fd_Submit="Submit" data-forms.trial.scenario.eula.headline.text="Terms &amp; Conditions" data-forms.trial.scenario.technicalerror.headline.title="Get your free trial" data-forms.trial.scenario.technicalerror.headline.text="Thanks for your interest in a free trial" data-forms.trial.scenario.technicalerror.message="Unfortunately, a technical error occurred when processing your request. Please try again." data-form.registration.confirmationscreen.link.text="Return to SAP.com" data-forms.trial.scenario.confirmation.headline.text="Welcome to your free trial" data-forms.trial.scenario.confirmation.button.label="Click here to start your trial!" data-forms.trial.scenario.technicalerror.nonexistingtrial.message="Our apologies, but the requested trial does not exist." data-forms.trial.scenario.technicalerror.secondaryevaluation.message="Our apologies, but this solution cannot currently be provided. We will e-mail you as soon as this problem has been solved." data-forms.trial.scenario.eula.validation.text="Please acknowledge that you have read the Terms &amp; Conditions." data-forms.trial.scenario.sactechnicalerror.paragraph.text="Due to a high volume of signups, we’ve temporarily paused new advanced free trial registrations until we have more availability. Please try again in a day or two." data-forms.generic.scenario.gtscheckfailed.message="Your request for information is being reviewed. Once approved, you’ll receive an e-mail with additional instructions." data-forms.generic.scenario.gtsdatamismatched.message="Some of your information doesn’t match what we have in your profile. Please log out of SAP.com, log in with the correct account, and resubmit the form with the original information provided." data-forms.registration.statusbar.register.label="Register" data-forms.registration.statusbar.verifyemail.label="Verify your e-mail" data-forms.registration.statusbar.eula.label="Accept Terms &amp; Conditions" data-forms.registration.statusbar.viewContent.label="Access your content" data-forms.registration.statusbar.accessresources.label="Access all resources" data-generic.accessibility.loadinganimation.text="Loading">
</div>
</div>
<div class="hidden lightboxI18nContainer" data-forms.lightbox.documentnotfound.maintitle.text="Message" data-forms.lightbox.documentnotfound.headline.text="Document can’t be found" data-forms.lightbox.documentnotfound.paragraph.text="Our apologies! The document you are looking for may have been removed or is temporarily unavailable." data-forms.lightbox.documentnotfound.submit.button.label="Ok" data-forms.lightbox.videonotfound.maintitle.text="Message" data-forms.lightbox.videonotfound.headline.text="Video can’t be found" data-forms.lightbox.videonotfound.paragraph.text="Our apologies! The video you are looking for may have been removed or is temporarily unavailable." data-forms.lightbox.videonotfound.submit.button.label="Ok" data-lightbox.search.nomatches.text="Phrase not found" data-lightbox.search.totalmatches.template="{0} entries found" data-lightbox.search.currentmatch.template="{0} of {1}" data-lightbox.close.label="Close" data-lightbox.sharing.mailto.linkalt.text="Share via email">
</div>
<script class="markupLigtbox" type="text/x-handlebars-template">
    <div class="lightboxPopup" id="openPopup">
        <section>
            <div class="loadingBar">
                <div class="bar bar-first"></div>
                <div class="bar bar-second"></div>
                <div class="bar bar-third"></div>
            </div>
        </section>
        <div class="lightboxContainer">
            <div class="popupHeader container-extended">
                <div class="header-container grid-container">
                    <div class="row">
                        <div class="col-xs-11 col-sm-10 col-md-10 col-lg-10">
                            <div class="sectionTitle he fontBook">{{assetTitle}}</div>
                            <div class="descriptionText text">{{assetDescription}}</div>
                        </div>
                    </div>
                </div>
                <div class="toolbar-container {{#if pageRating}}{{pageRating}} col-xlg-12 col-lg-12 col-md-12 col-xs-12 col{{/if}}">
                    <nav class="toolbar">
                        <ul class="toolbar-list">
                            <li><a title="Download the asset" id="download-link" class="toolbtn download icon-download exclude-ligthbox-handler"></a></li>
                            <li><a title="Share via email" target="_top" class="toolbtn mail icon-email exclude-ligthbox-handler" data-share-tracking-analytics="SHARE" data-share-channel="mailto"></a></li>
                            <li class="share-wrap"><a class="toolbtn share icon-share"></a>
                                <ul class="share-dropdown">
                                    {{#each socialItems}}
                                        <li class="fontLight">
                                            <a
                                                title="{{title}}"
                                                data-share-channel="{{share-channel}}"
                                                data-share-tracking-analytics="SHARE"
                                                target="_blank"
                                                data-share-url="{{resourceLink}}"
                                                data-is-share-link="true"
                                            >
                                                <span class="{{class}}"></span>{{title}}
                                            </a>
                                        </li>
                                    {{/each }}
                                </ul>
                            </li>
                            <li class="rating-message initial hidden">
                                <div class="thanksLikeBlock ds-body ds-body--l fontBook"></div>
                                <div class="thanksDisliking fontRegular"></div>
                                <div class="question firstQuestion initial">
                                    <div class="question-headline ds-body fontBook"></div>
                                    <div class="question-buttons">
                                        <div class="button-block">
                                            <a class="like-button ds-button ds-button--secondary fontRegular ds-m-r-m ds-m-l-l"></a>
                                            <a class="dislike-button dislike-icon ds-button ds-button--secondary fontRegular"></a>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </nav>
                    <div class="toolbtn exit icon-close mfp-close"></div>
                </div>
                <div class="question-container">
                    <div class="rating-wrapper-lightbox fontBook">
                        <div class="question secondQuestion col-xlg-10 col-lg-10 col-sm-10 col-md-10 col">
                            <div class="blockReasons">
                                <div class="question-wrapper">
                                    <div class="questionText"></div>
                                    <ul class="radio-rating ds-m-t-m"></ul>
                                </div>
                            </div>
                        </div>
                        <div class="close-feedback icon-close"></div>
                    </div>
                </div>
            </div>
            <div class="popupContent">
                {{{popupContent}}}
            </div>
            <div class="popupFooter">
                {{#if isFooterConfigured}}
                <div class="footer-container grid-container">
                    <div class="row">
                        <div class="col-xs-7 col-sm-12 col-md-12 col-lg-12">
                            <div class="info-container">
                                <div class="he footer-headine fontBook">{{assetFooterTitle}}</div>
                                <div class="text footer-paragraph">{{assetFooterDescription}}</div>
                            </div>
                        </div>
                        <div class="btn-wrapper col-xs-5 col-sm-5 col-md-5 col-lg-5">
                            {{#if assetFooterLinkName}}
                                <a href="{{assetFooterLinkPath}}" target="{{assetFooterLinkTarget}}"
                                   class="button2017 fontRegular version1 lightbox-footer-link">
                                    <span class="buttonText">{{assetFooterLinkName}}</span>
                                    <span class="hoverboxes"><span class="hoverbox"></span><span
                                            class="hoverbox"></span><span class="hoverbox"></span></span>
                                </a>
                            {{/if}}
                        </div>
                    </div>
                </div>
                {{/if}}
            </div>
        </div>
        <div class="qrCodePopup" id="qrCode" data-component="QRCodeGenerator" data-component-id="wechat-share"></div>
    </div>
</script>
<script class="feedbackLightbox" type="text/x-handlebars-template">
    <div class="lightboxPopup lightboxFeedback fontRegular" id="openPopup">
        <div class="wrapper">
            <div class="header">
                <div class="title he fontBook">{{assetTitle}}</div>
                <div class="toolbtn exit icon-close mfp-close"></div>
            </div>
            <div class="popupContent">
                {{{popupContent}}}
            </div>
        </div>
    </div>
</script>
<script class="messageLightbox" type="text/x-handlebars-template">
    <div class="popup-header">
        <p class="title">{{headerMessage}}</p>
        <button class="close-button" type="button" title="{{closeButtonLabel}}">
            <svg height='16' viewBox='0 0 16 16' width='16' xmlns='http://www.w3.org/2000/svg'>
                <path d='m0 0h16v16h-16z' fill='#fff' opacity='0' />
                <path d='m12.2 13c-.2 0-.41-.08-.57-.23l-3.63-3.63-3.63 3.63c-.31.31-.82.31-1.13 0s-.31-.82 0-1.13l3.63-3.63-3.63-3.63c-.31-.31-.31-.82 0-1.13s.82-.31 1.13 0l3.63 3.63 3.63-3.63c.31-.31.82-.31 1.13 0s.31.82 0 1.13l-3.63 3.63 3.63 3.63c.31.31.31.82 0 1.13-.16.16-.36.23-.57.23z' />
            </svg>
        </button>
    </div>
    <div class="popup-container">
        {{> content}}
        <div class="loading-bar-overlay">
            <div class="loadingBar">
                <div class="bar bar-first"></div>
                <div class="bar bar-second"></div>
                <div class="bar bar-third"></div>
            </div>
        </div>
    </div>
</script>
<script class="html-content-lightbox" type="text/x-handlebars-template">
    <div class="popupHeader">
        {{#if isHeaderConfigured}}
        <div class="header-container">
            <h2 id="magnific-popup-header-headline" class="sectionTitle he" aria-hidden="true">{{assetTitle}}</h2>
            <div class="descriptionText text">{{assetDescription}}</div>
        </div>
        {{/if}}
        <div class="toolbar-container">
            {{#if isHeaderConfigured}}
            {{#if isEnabledShareLink}}
            <nav class="toolbar">
                <ul class="toolbar-list">
                    <li><a title="Share via email" class="toolbtn mail icon-email exclude-ligthbox-handler" data-share-tracking-analytics="SHARE" data-share-channel="mailto"></a></li>
                    <li class="share-wrap"><a class="toolbtn share icon-share"></a>
                        <ul class="share-dropdown">
                            {{#each socialItems}}
                                <li class="fontLight">
                                    <a
                                        title="{{title}}"
                                        data-share-channel="{{share-channel}}"
                                        data-share-tracking-analytics="SHARE"
                                        target="_blank"
                                        data-share-url="{{resourceLink}}"
                                        data-is-share-link="true"
                                    >
                                        <span class="{{class}}"></span>{{title}}
                                    </a>
                                </li>
                            {{/each }}
                        </ul>
                    </li>
                </ul>
            </nav>
            {{/if}}
            {{/if}}
            <button class="toolbtn exit icon-close mfp-close" title="{{closeButtonLabel}}">
                <svg height='16' viewBox='0 0 16 16' width='16' xmlns='http://www.w3.org/2000/svg'>
                    <path d='m0 0h16v16h-16z' fill='#fff' opacity='0' />
                    <path d='m12.2 13c-.2 0-.41-.08-.57-.23l-3.63-3.63-3.63 3.63c-.31.31-.82.31-1.13 0s-.31-.82 0-1.13l3.63-3.63-3.63-3.63c-.31-.31-.31-.82 0-1.13s.82-.31 1.13 0l3.63 3.63 3.63-3.63c.31-.31.82-.31 1.13 0s.31.82 0 1.13l-3.63 3.63 3.63 3.63c.31.31.31.82 0 1.13-.16.16-.36.23-.57.23z' />
                </svg>
            </button>
        </div>
    </div>
    <div class="popup-container">
        <iframe
            class="html-content-lightbox-frame"
            src={{src}}
            width='1100px' height='700px'>
        </iframe>
    </div>
    <div class="popupFooter">
        {{#if isFooterConfigured}}
        <div class="footer-container grid-container">
            <div class="row">
                <div class="col-xs-7 col-sm-12 col-md-12 col-lg-12">
                    <div class="info-container">
                        <div class="he fontBook footer-headine">{{assetFooterTitle}}</div>
                        <div class="text footer-paragraph">{{assetFooterDescription}}</div>
                    </div>
                </div>
                <div class="btn-wrapper col-xs-5 col-sm-5 col-md-5 col-lg-5">
                    <a href="{{assetFooterLinkPath}}" target="{{assetFooterLinkTarget}}"
                       class="button2017 fontRegular version1 lightbox-footer-link">
                        <span class="buttonText">{{assetFooterLinkName}}</span>
                        <span class="hoverboxes"><span class="hoverbox"></span><span
                                class="hoverbox"></span><span class="hoverbox"></span></span>
                    </a>
                </div>
            </div>
        </div>
        {{/if}}
    </div>
</script>
